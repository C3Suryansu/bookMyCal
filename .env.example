# Telegram bot token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Optional: override the Claude model used by the agent
# Defaults to claude-opus-4-5
# ANTHROPIC_MODEL=claude-opus-4-5

# Note: The Anthropic API key is collected per-user during onboarding
# and stored in-memory. It is NOT set here.
